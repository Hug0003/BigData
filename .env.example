# ------------------------------------------------------------------------------
# PROJECT CONFIGURATION EXAMPLE
# Copy this file to .env and fill in the missing values
# ------------------------------------------------------------------------------

# API KEYS
# Register on https://www.geoapify.com/ to get your free API key
GEOAPIFY_API_KEY=your_geoapify_key_here

# ENVIRONMENT CONFIG
# Example: Europe/Paris, UTC, America/New_York
TZ=Europe/Paris

# OPENSKY NETWORK CREDENTIALS (Optional for higher rate limits)
# Register on https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# MINIO CONFIGURATION (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_BROWSER_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=raw-api-data
MINIO_SECURE=false

# POSTGRES CONFIGURATION (Data Warehouse)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=postgres

# AIRFLOW CONFIGURATION
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
# Generate a secret key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_generated_fernet_key_here

# GRAFANA CONFIGURATION
GRAFANA_ADMIN_PASSWORD=admin

# MONITORING CONFIGURATION
METRICS_PORT=8000
METRICS_INTERVAL=30
